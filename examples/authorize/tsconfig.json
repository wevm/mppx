{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "mppx": ["../../src/index.ts"],
      "mppx/client": ["../../src/client/index.ts"],
      "mppx/server": ["../../src/server/index.ts"],
      "mppx/tempo": ["../../src/tempo/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
