{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals", "vitest/importMeta"],
    "paths": {
      "~test/*": ["./*"],
      "mppx": ["../src/index.ts"],
      "mppx/client": ["../src/client/index.ts"],
      "mppx/proxy": ["../src/proxy/index.ts"],
      "mppx/server": ["../src/server/index.ts"],
      "mppx/tempo": ["../src/tempo/index.ts"],
      "mppx/hono": ["../src/middlewares/hono.ts"],
      "mppx/express": ["../src/middlewares/express.ts"],
      "mppx/nextjs": ["../src/middlewares/nextjs.ts"],
      "mppx/elysia": ["../src/middlewares/elysia.ts"],
      "mppx/stripe": ["../src/stripe/index.ts"],
      "mppx/stripe/client": ["../src/stripe/client/index.ts"],
      "mppx/stripe/server": ["../src/stripe/server/index.ts"],
      "mppx/mcp-sdk/client": ["../src/mcp-sdk/client/index.ts"],
      "mppx/mcp-sdk/server": ["../src/mcp-sdk/server/index.ts"]
    }
  },
  "include": [
    "env.d.ts",
    "./**/*.ts",
    "../src/**/*.test.ts",
    "../src/**/*.test-d.ts"
  ]
}
