{
  "scripts": {
    "build": "zile",
    "dev": "zile dev",
    "dev:example": "node scripts/dev:example.ts",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version",
    "check": "biome check --fix --unsafe",
    "check:ci": "biome check",
    "check:types": "tsc -b",
    "mpay": "node --import tsx src/cli.ts",
    "test": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@changesets/cli": "latest",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.0.17",
    "prool": "^0.2.2",
    "testcontainers": "^11.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "viem": "^2.44.4",
    "vitest": "latest",
    "zile": "^0.0.19",
    "zod": "^4.3.5"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "mpay": "workspace:*",
      "ox": "^0.12.0",
      "viem": "latest"
    }
  },
  "[!start-pkg]": "",
  "name": "mpay",
  "type": "module",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "src": "./src/client/index.ts",
      "default": "./dist/client/index.js"
    },
    "./mcp-sdk/client": {
      "types": "./dist/mcp-sdk/client/index.d.ts",
      "src": "./src/mcp-sdk/client/index.ts",
      "default": "./dist/mcp-sdk/client/index.js"
    },
    "./mcp-sdk/server": {
      "types": "./dist/mcp-sdk/server/index.d.ts",
      "src": "./src/mcp-sdk/server/index.ts",
      "default": "./dist/mcp-sdk/server/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "src": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    },
    "./tempo": {
      "types": "./dist/tempo/index.d.ts",
      "src": "./src/tempo/index.ts",
      "default": "./dist/tempo/index.js"
    }
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.25.0",
    "viem": ">=2.44.4",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "dependencies": {
    "cac": "^6.7.14",
    "ox": "^0.12.0"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mpay": "./dist/cli.js",
    "mpay.src": "./src/cli.ts"
  }
}
