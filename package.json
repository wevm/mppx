{
  "scripts": {
    "build": "zile",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version",
    "check": "biome check --fix --unsafe",
    "check:ci": "biome check",
    "check:types": "tsc -b",
    "check:types:examples": "pnpm -r --filter './examples/*' run check:types",
    "deps:ci": "pnpx actions-up",
    "dev": "zile dev",
    "dev:example": "node scripts/dev:example.ts",
    "mppx": "node --import tsx src/bin.ts",
    "check:compat": "eslint -c eslint.compat.config.mjs 'src/**/*.ts' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.test-d.ts'",
    "test": "vitest"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all",
    "not kaios >= 0",
    "not android >= 0",
    "not and_uc >= 0",
    "not and_qq >= 0",
    "not and_ff >= 0",
    "node >= 18"
  ],
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@changesets/cli": "latest",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/express": "^5.0.6",
    "@types/node": "latest",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.17",
    "browserslist": "^4.28.1",
    "elysia": "^1.4.27",
    "file-type": "^21.3.2",
    "eslint": "^9.28.0",
    "eslint-plugin-compat": "^7.0.1",
    "express": "^5.2.1",
    "hono": "^4.11.9",
    "playwright": "^1.58.2",
    "prool": "^0.2.2",
    "testcontainers": "^11.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "viem": "^2.46.2",
    "vitest": "latest",
    "zile": "^0.0.19"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "mppx": "workspace:*",
      "ox": "^0.14.1",
      "viem": "^2.46.2",
      "tar@<=7.5.10": "7.5.11",
      "@modelcontextprotocol/sdk@>=1.10.0 <=1.25.3": "1.26.0",
      "qs@>=6.7.0 <=6.14.1": "6.14.2",
      "hono@<4.12.7": "4.12.7",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "@hono/node-server@<1.19.10": "1.19.10",
      "elysia@<1.4.26": "1.4.26",
      "file-type": "21.3.2",
      "flatted@<3.4.0": "3.4.0",
      "undici@>=7.0.0 <7.24.0": "7.24.0"
    }
  },
  "[!start-pkg]": "",
  "name": "mppx",
  "type": "module",
  "version": "0.4.5",
  "main": "./dist/index.js",
  "license": "MIT",
  "files": [
    "CHANGELOG.md",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/config.d.ts",
      "src": "./src/cli/config.ts",
      "default": "./dist/cli/config.js"
    },
    "./cli/plugins": {
      "types": "./dist/cli/plugins/index.d.ts",
      "src": "./src/cli/plugins/index.ts",
      "default": "./dist/cli/plugins/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "src": "./src/client/index.ts",
      "default": "./dist/client/index.js"
    },
    "./mcp-sdk/client": {
      "types": "./dist/mcp-sdk/client/index.d.ts",
      "src": "./src/mcp-sdk/client/index.ts",
      "default": "./dist/mcp-sdk/client/index.js"
    },
    "./mcp-sdk/server": {
      "types": "./dist/mcp-sdk/server/index.d.ts",
      "src": "./src/mcp-sdk/server/index.ts",
      "default": "./dist/mcp-sdk/server/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "src": "./src/proxy/index.ts",
      "default": "./dist/proxy/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "src": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    },
    "./stripe": {
      "types": "./dist/stripe/index.d.ts",
      "src": "./src/stripe/index.ts",
      "default": "./dist/stripe/index.js"
    },
    "./stripe/client": {
      "types": "./dist/stripe/client/index.d.ts",
      "src": "./src/stripe/client/index.ts",
      "default": "./dist/stripe/client/index.js"
    },
    "./stripe/server": {
      "types": "./dist/stripe/server/index.d.ts",
      "src": "./src/stripe/server/index.ts",
      "default": "./dist/stripe/server/index.js"
    },
    "./tempo": {
      "types": "./dist/tempo/index.d.ts",
      "src": "./src/tempo/index.ts",
      "default": "./dist/tempo/index.js"
    },
    "./hono": {
      "types": "./dist/middlewares/hono.d.ts",
      "src": "./src/middlewares/hono.ts",
      "default": "./dist/middlewares/hono.js"
    },
    "./express": {
      "types": "./dist/middlewares/express.d.ts",
      "src": "./src/middlewares/express.ts",
      "default": "./dist/middlewares/express.js"
    },
    "./nextjs": {
      "types": "./dist/middlewares/nextjs.d.ts",
      "src": "./src/middlewares/nextjs.ts",
      "default": "./dist/middlewares/nextjs.js"
    },
    "./elysia": {
      "types": "./dist/middlewares/elysia.d.ts",
      "src": "./src/middlewares/elysia.ts",
      "default": "./dist/middlewares/elysia.js"
    }
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.25.0",
    "elysia": ">=1",
    "express": ">=5",
    "hono": ">=4",
    "viem": ">=2.46.2"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "@remix-run/fetch-proxy": "^0.7.1",
    "@remix-run/node-fetch-server": "^0.13.0",
    "incur": "^0.3.1",
    "ox": "^0.14.1",
    "zod": "^4.3.6"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mppx": "./dist/bin.js",
    "mppx.src": "./src/bin.ts"
  }
}
