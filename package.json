{
  "scripts": {
    "build": "pnpm build:html && zile",
    "build:html": "node --import tsx scripts/build:html.ts",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version && vp fmt .",
    "check": "vp lint --fix && vp fmt --write .",
    "check:ci": "vp lint && vp fmt --check .",
    "check:types": "pnpm build:html && tsgo -b",
    "check:types:html": "tsgo -p src/tempo/server/internal/html/tsconfig.json && tsgo -p src/stripe/server/internal/html/tsconfig.json",
    "check:types:examples": "pnpm -r --filter './examples/**' run check:types",
    "deps": "pnpx taze -r --no-ignore-other-workspaces --ignore-paths node_modules",
    "deps:ci": "pnpx actions-up",
    "dev": "zile dev",
    "dev:example": "node scripts/dev:example.ts",
    "mppx": "node --import tsx src/bin.ts",
    "test": "vp test",
    "test:html": "playwright test --config test/html/playwright.config.ts"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all",
    "not kaios >= 0",
    "not android >= 0",
    "not and_uc >= 0",
    "not and_qq >= 0",
    "not and_ff >= 0",
    "node >= 18"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@hono/node-server": "2.0.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260323.1",
    "browserslist": "^4.28.2",
    "elysia": "^1.4.28",
    "eslint-plugin-compat": "^7.0.2",
    "express": "^5.2.1",
    "fast-check": "^4.8.0",
    "file-type": "22.0.1",
    "hono": "4.12.23",
    "isows": "^1.0.7",
    "playwright": "^1.60.0",
    "prool": "^0.2.4",
    "rolldown": "1.0.3",
    "tempo.ts": "^0.14.2",
    "testcontainers": "^12.0.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "viem": "^2.51.3",
    "vite": "^8.0.10",
    "vp": "npm:vite-plus@~0.1.17",
    "ws": "^8.21.0",
    "zile": "^0.0.29"
  },
  "packageManager": "pnpm@11.0.8",
  "[!start-pkg]": "",
  "name": "mppx",
  "type": "module",
  "version": "0.6.31",
  "main": "./dist/index.js",
  "license": "MIT",
  "files": [
    "CHANGELOG.md",
    "dist",
    "src"
  ],
  "exports": {
