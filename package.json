{
  "scripts": {
    "build": "zile",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version",
    "check": "vp lint --fix && vp fmt --write .",
    "check:ci": "vp lint && vp fmt --check .",
    "check:types": "tsgo -b",
    "check:types:examples": "pnpm -r --filter './examples/**' run check:types",
    "deps": "pnpx taze -r --no-ignore-other-workspaces --ignore-paths node_modules",
    "deps:ci": "pnpx actions-up",
    "dev": "zile dev",
    "dev:example": "node scripts/dev:example.ts",
    "mppx": "node --import tsx src/bin.ts",
    "test": "vp test"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all",
    "not kaios >= 0",
    "not android >= 0",
    "not and_uc >= 0",
    "not and_qq >= 0",
    "not and_ff >= 0",
    "node >= 18"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260323.1",
    "browserslist": "^4.28.1",
    "elysia": "^1.4.27",
    "eslint-plugin-compat": "^7.0.1",
    "express": "^5.2.1",
    "fast-check": "^4.6.0",
    "file-type": "^21.3.2",
    "hono": "^4.11.9",
    "playwright": "^1.58.2",
    "prool": "^0.2.4",
    "tempo.ts": "^0.14.2",
    "testcontainers": "^11.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "viem": "^2.47.6",
    "vp": "npm:vite-plus@~0.1.14",
    "zile": "^0.0.19"
  },
  "packageManager": "pnpm@10.28.0",
  "[!start-pkg]": "",
  "name": "mppx",
  "type": "module",
  "version": "0.4.12",
  "main": "./dist/index.js",
  "license": "MIT",
  "files": [
    "CHANGELOG.md",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/config.d.ts",
      "src": "./src/cli/config.ts",
      "default": "./dist/cli/config.js"
    },
    "./cli/plugins": {
      "types": "./dist/cli/plugins/index.d.ts",
      "src": "./src/cli/plugins/index.ts",
      "default": "./dist/cli/plugins/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "src": "./src/client/index.ts",
      "default": "./dist/client/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "src": "./src/discovery/index.ts",
      "default": "./dist/discovery/index.js"
    },
    "./mcp-sdk/client": {
      "types": "./dist/mcp-sdk/client/index.d.ts",
      "src": "./src/mcp-sdk/client/index.ts",
      "default": "./dist/mcp-sdk/client/index.js"
    },
    "./mcp-sdk/server": {
      "types": "./dist/mcp-sdk/server/index.d.ts",
      "src": "./src/mcp-sdk/server/index.ts",
      "default": "./dist/mcp-sdk/server/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "src": "./src/proxy/index.ts",
      "default": "./dist/proxy/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "src": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    },
    "./stripe": {
      "types": "./dist/stripe/index.d.ts",
      "src": "./src/stripe/index.ts",
      "default": "./dist/stripe/index.js"
    },
    "./stripe/client": {
      "types": "./dist/stripe/client/index.d.ts",
      "src": "./src/stripe/client/index.ts",
      "default": "./dist/stripe/client/index.js"
    },
    "./stripe/server": {
      "types": "./dist/stripe/server/index.d.ts",
      "src": "./src/stripe/server/index.ts",
      "default": "./dist/stripe/server/index.js"
    },
    "./tempo": {
      "types": "./dist/tempo/index.d.ts",
      "src": "./src/tempo/index.ts",
      "default": "./dist/tempo/index.js"
    },
    "./hono": {
      "types": "./dist/middlewares/hono.d.ts",
      "src": "./src/middlewares/hono.ts",
      "default": "./dist/middlewares/hono.js"
    },
    "./express": {
      "types": "./dist/middlewares/express.d.ts",
      "src": "./src/middlewares/express.ts",
      "default": "./dist/middlewares/express.js"
    },
    "./nextjs": {
      "types": "./dist/middlewares/nextjs.d.ts",
      "src": "./src/middlewares/nextjs.ts",
      "default": "./dist/middlewares/nextjs.js"
    },
    "./elysia": {
      "types": "./dist/middlewares/elysia.d.ts",
      "src": "./src/middlewares/elysia.ts",
      "default": "./dist/middlewares/elysia.js"
    }
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.25.0",
    "elysia": ">=1",
    "express": ">=5",
    "hono": ">=4",
    "viem": ">=2.47.5"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "@remix-run/fetch-proxy": "^0.7.1",
    "@remix-run/node-fetch-server": "^0.13.0",
    "incur": "^0.3.1",
    "ox": "^0.14.1",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wevm/mppx.git"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mppx": "./dist/bin.js",
    "mppx.src": "./src/bin.ts"
  }
}
